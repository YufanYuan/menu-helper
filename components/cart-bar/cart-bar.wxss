.cart-bar {
  position: sticky;
  bottom: 0;
  margin-top: 28rpx;
  padding: 18rpx 20rpx 18rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-radius: 28rpx;
  background: #182126;
  box-shadow: 0 14rpx 30rpx rgba(24, 33, 38, 0.18);
}

.cart-bar.disabled {
  background: rgba(24, 33, 38, 0.34);
  box-shadow: none;
}

.cart-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex-shrink: 0;
}

.cart-count {
  color: rgba(255, 250, 240, 0.75);
  font-size: 22rpx;
}

.cart-price {
  color: #fffaf0;
  font-size: 34rpx;
  font-weight: 700;
}

.cart-action {
  flex: none;
  min-width: 188rpx;
  min-height: 76rpx;
  padding: 0 30rpx;
  border-radius: 999rpx;
  background: #fffaf0;
  color: #182126;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.cart-bar.disabled .cart-action {
  background: rgba(255, 250, 240, 0.78);
  color: rgba(24, 33, 38, 0.4);
}
