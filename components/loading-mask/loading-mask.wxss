.mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  width: 100vw;
  top: 0;
  left: 0;
  padding: 40rpx;
  background: rgba(24, 33, 38, 0.42);
}

.mask-card {
  width: 100%;
  max-width: 560rpx;
  padding: 42rpx 38rpx;
  border-radius: 32rpx;
  background: #fffaf0;
  text-align: center;
}

.spinner {
  width: 80rpx;
  height: 80rpx;
  margin: 0 auto 24rpx;
  border: 8rpx solid rgba(24, 33, 38, 0.12);
  border-top-color: #182126;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
}

.mask-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.mask-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #5e655f;
  font-size: 24rpx;
  line-height: 1.5;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
