FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

COPY --from=ghcr.io/astral-sh/uv:0.5.31 /uv /uvx /bin/

WORKDIR /app

COPY pyproject.toml uv.toml .python-version ./
COPY backend/cn-backend ./backend/cn-backend

RUN uv sync --package menu-helper-cn-backend --no-dev

EXPOSE 8000

CMD ["uv", "run", "--package", "menu-helper-cn-backend", "uvicorn", "menu_helper_cn_backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
