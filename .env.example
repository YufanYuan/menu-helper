# CN backend Docker runtime configuration

# Host ports used by docker compose.
CN_BACKEND_PORT=8000
FRONTEND_PORT=8080

# Required for WebSocket room member auth.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Redis stores shared room state across backend instances.
REDIS_URL=redis://redis:6379/0

# WebSocket endpoints returned by GET /api/config.
# Leave values empty only if this deployment should not advertise that endpoint.
ROOMS_SOCKET_URL=
ROOMS_CN_SOCKET_URL=

# International clients use the Cloudflare Worker room endpoint.
# Example: wss://your-worker.example.workers.dev/ws/rooms
ROOMS_CLOUDFLARE_SOCKET_URL=
