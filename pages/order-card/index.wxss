page {
  height: 100vh;
}

.screen {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.page-shell {
  flex: 1;
  min-height: 0;
  padding: 16rpx;
  max-height: 100%;
}

.page-body {
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.hero-card {
  padding: 30rpx 28rpx;
}

.switch-row {
  margin-top: 24rpx;
}

.order-sheet {
  margin-top: 24rpx;
  padding: 32rpx 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 252, 246, 0.98), rgba(247, 240, 230, 0.98));
    overflow: hidden;
}

.sheet-header {
  display: block;
  padding-bottom: 22rpx;
  border-bottom: 1rpx dashed rgba(24, 33, 38, 0.14);
  font-size: 26rpx;
  color: #5e655f;
}

.sheet-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
}

.sheet-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 18rpx;
  margin-top: 4rpx;
  
}

.sheet-quantity {
  flex: none;
  min-width: 82rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.sheet-name {
  flex: 1;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 600;
}

.action-button {
  margin-top: 28rpx;
  width: 100% !important;
  flex: none;
}

.empty-shell {
  margin-top: 80rpx;
  padding: 36rpx 28rpx;
}

.empty-button {
  margin-top: 28rpx;
  width: 100%;
}
