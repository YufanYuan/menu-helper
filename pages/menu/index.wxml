<view class="screen">
  <navigation-bar
    title="菜单浏览"
    color="#182126"
    background="transparent"
    delta="{{0}}"
    bind:back="handleBackAttempt"
  ></navigation-bar>

  <view class="page-shell">
    <view wx:if="{{hasMenu}}" class="page-body">
      <view id="summary-card" class="card summary-card">
        <view class="summary-copy">
          <text class="section-title">菜单识别完成</text>
          <text class="section-subtitle">原文：{{menuLanguageLabel}} · 翻译：{{userLanguage}}</text>
        </view>
        <image wx:if="{{imagePath}}" class="summary-image" src="{{imagePath}}" mode="aspectFill"></image>
      </view>

      <scroll-view
        id="category-row"
        class="category-row"
        scroll-x="{{true}}"
        enable-flex="{{true}}"
        show-scrollbar="{{false}}"
      >
        <block wx:for="{{categories}}" wx:key="*this">
          <view
            class="category-pill {{activeCategory === item ? 'active' : ''}}"
            data-category="{{item}}"
            bindtap="handleCategoryTap"
          >
            {{item}}
          </view>
        </block>
      </scroll-view>

      <scroll-view
        id="menu-list"
        scroll-y="{{true}}"
        scroll-top="{{menuScrollTop}}"
        class="menu-list"
      >
        <block wx:for="{{items}}" wx:key="id">
          <menu-item-card item="{{item}}" quantity="{{item.quantity}}" bind:quantitychange="handleQuantityChange"></menu-item-card>
        </block>
      </scroll-view>

      <cart-bar
        id="cart-bar"
        totalCount="{{totalCount}}"
        totalPriceLabel="{{totalPriceLabel}}"
        disabled="{{!totalCount}}"
        bind:preview="handlePreview"
      ></cart-bar>
    </view>

    <view wx:else class="empty-shell card">
      <text class="section-title">还没有菜单结果</text>
      <text class="section-subtitle">先回到首页上传菜单，再开始点餐。</text>
      <button class="primary-button empty-action" bindtap="handleRestart">回到首页</button>
    </view>
  </view>
</view>
