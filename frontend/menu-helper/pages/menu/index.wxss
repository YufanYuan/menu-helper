page {
  height: 100vh;
}

.screen {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.page-shell {
  flex: 1;
  min-height: 0;
  box-sizing: border-box;
  padding: 16rpx;
}

.page-body {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

.summary-card {
  flex-shrink: 0;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.summary-copy {
  flex: 1;
}

.summary-subtitle-extra {
  display: block;
  margin-top: 12rpx;
  color: #5e655f;
  font-size: 24rpx;
}

.summary-image {
  flex: none;
  width: 148rpx;
  height: 148rpx;
  border-radius: 24rpx;
}

.category-row {
  display: flex;
  flex-direction: row;
  flex-shrink: 0;
  align-items: center;
  max-width: 100%;
  height: 112rpx;
  padding: 24rpx 0;
  white-space: nowrap;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  min-width: 120rpx;
  padding: 0 24rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: rgba(24, 33, 38, 0.06);
  color: #5e655f;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.category-pill.active {
  background: #182126;
  color: #fffaf0;
}

.menu-list {
  width: 100%;
  flex: 1;
  min-height: 0;
  padding-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  overflow: hidden;
}

.empty-shell {
  margin-top: 80rpx;
  padding: 36rpx 28rpx;
}

.empty-action {
  margin-top: 28rpx;
}

#cart-bar {
  flex-shrink: 0;
}
