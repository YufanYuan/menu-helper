<navigation-bar title="菜单助手" back="{{false}}" color="#182126" background="transparent"></navigation-bar>

<view class="page-shell">

  <view class="page-body">
    <view wx:if="{{configLoadError}}" class="card settings-card">
      <view>
        <text class="section-title">配置加载失败</text>
        <text class="section-subtitle">{{configLoadError}}</text>
      </view>
      <button class="primary-button" bindtap="handleRetryConfig">重试加载配置</button>
    </view>

    <image-picker
      imagePaths="{{imagePaths}}"
      uploadLimit="{{uploadLimit}}"
      bind:selected="handleImageSelected"
      bind:cleared="handleImageCleared"
    ></image-picker>

    <view class="card settings-card">
      <view>
        <text class="section-title">翻译语言</text>
        <text class="section-subtitle">识别结果将优先显示为该语言</text>
      </view>
      <picker mode="selector" range="{{languageOptions}}" value="{{selectedLanguageIndex}}" bindchange="handleLanguageChange">
        <view class="picker-row">
          <text>{{languageOptions[selectedLanguageIndex]}}</text>
          <text class="picker-arrow">></text>
        </view>
      </picker>
    </view>

    <button class="primary-button action-button {{!imagePaths.length || isConfigLoading || configLoadError ? 'disabled' : ''}}" bindtap="handleRecognize">
      识别菜单
    </button>
  </view>
</view>

<loading-mask visible="{{isConfigLoading || isAnalyzing}}" title="{{loadingTitle}}" subtitle="{{loadingSubtitle}}" estimateSeconds="{{isConfigLoading ? 8 : 60}}" targetProgress="{{isConfigLoading ? 0.6 : 0.8}}"></loading-mask>
