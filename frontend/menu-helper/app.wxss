page {
  min-height: 100%;
  background: #f5f1e8;
  color: #182126;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
image,
scroll-view,
swiper,
picker {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 1;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 0 28rpx 40rpx;
}

.page-body {
  padding-bottom: calc(env(safe-area-inset-bottom));
}

.card {
  background: rgba(255, 252, 246, 0.92);
  border: 1rpx solid rgba(24, 33, 38, 0.08);
  border-radius: 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(24, 33, 38, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.3;
}

.section-subtitle {
  margin-top: 10rpx;
  color: #5e655f;
  font-size: 24rpx;
  line-height: 1.5;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 999rpx;
  background: #182126;
  color: #fffaf0;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-button.disabled {
  opacity: 0.45;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 999rpx;
  background: rgba(24, 33, 38, 0.06);
  color: #182126;
  font-size: 28rpx;
  font-weight: 600;
}

.muted-text {
  color: #6f786d;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(24, 33, 38, 0.06);
  color: #182126;
  font-size: 24rpx;
}
