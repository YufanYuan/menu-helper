.menu-card {
  padding: 28rpx;
  margin-bottom: 12rpx;
}

.menu-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.menu-copy {
  flex: 1;
  min-width: 0;
}

.menu-primary-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.menu-secondary-name {
  display: block;
  margin-top: 10rpx;
  color: #9d5a36;
  font-size: 26rpx;
  line-height: 1.4;
}

.menu-description {
  display: block;
  margin-top: 12rpx;
  color: #5e655f;
  font-size: 24rpx;
  line-height: 1.5;
}

.menu-price {
  flex: none;
  color: #182126;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}

.menu-card-bottom {
  margin-top: 28rpx;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.menu-meta {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.menu-category {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(157, 90, 54, 0.1);
  color: #8a5233;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.attribution-avatar {
  flex: none;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  overflow: hidden;
}

.attribution-image {
  width: 100%;
  height: 100%;
}

quantity-stepper {
  flex: none;
  width: 250rpx;
}
