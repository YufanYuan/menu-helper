<view class="menu-card card">
  <view class="menu-card-top">
    <view class="menu-copy">
      <text class="menu-primary-name">{{item.translatedName || item.originalName}}</text>
      <text wx:if="{{item.translatedName}}" class="menu-secondary-name">{{item.originalName}}</text>
      <text wx:if="{{item.descriptionTranslated}}" class="menu-description">{{item.descriptionTranslated}}</text>
      <text wx:elif="{{item.descriptionOriginal}}" class="menu-description">{{item.descriptionOriginal}}</text>
    </view>
    <text class="menu-price">{{item.priceLabel}}</text>
  </view>

  <view class="menu-card-bottom">
    <view class="menu-meta">
      <text class="menu-category">{{item.translatedCategory}}</text>
      <view wx:if="{{attribution}}" class="attribution-avatar" style="background: {{attribution.avatarColor || '#182126'}};">
        <image wx:if="{{attribution.avatarUrl}}" class="attribution-image" src="{{attribution.avatarUrl}}" mode="aspectFill"></image>
      </view>
    </view>
    <quantity-stepper value="{{quantity}}" disabled="{{disabled}}" bind:change="handleQuantityChange"></quantity-stepper>
  </view>
</view>
