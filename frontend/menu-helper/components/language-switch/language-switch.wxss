.switch-shell {
  display: inline-flex;
  padding: 8rpx;
  border-radius: 999rpx;
  background: rgba(24, 33, 38, 0.07);
  width: 100%;
}

.switch-item {
  min-width: 160rpx;
  min-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  color: #5e655f;
  font-size: 26rpx;
  font-weight: 600;
}

.switch-item.active {
  background: #182126;
  color: #fffaf0;
}
