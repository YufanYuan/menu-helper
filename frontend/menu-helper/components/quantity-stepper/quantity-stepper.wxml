<view class="stepper {{disabled ? 'disabled' : ''}}">
  <button class="stepper-button" disabled="{{disabled}}" bindtap="handleMinus">-</button>
  <view class="stepper-value">
    <text>{{value}}</text>
  </view>
  <button class="stepper-button filled" disabled="{{disabled}}" bindtap="handlePlus">+</button>
</view>
